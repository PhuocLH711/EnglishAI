<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="32dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAiTutor"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:navigationIcon="@android:drawable/ic_media_previous"
        app:title="AI English Tutor"
        app:titleCentered="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imgTeacher"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="Giáo viên AI"
                android:scaleType="centerCrop"
                android:src="@drawable/teacher_jack"/>

            <TextView
                android:id="@+id/tvTeacherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Emma"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Sẵn sàng giúp bạn học tiếng Anh!"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvAiResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_ai_response"
                android:padding="18dp"
                android:text="Xin chào! Hôm nay bạn muốn học gì?"
                android:textSize="17sp" />

            <Button
                android:id="@+id/btnSpeakToAi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="🎤 Nói với giáo viên" />

            <Button
                android:id="@+id/btnTypeQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="⌨ Nhập câu hỏi" />

            <Button
                android:id="@+id/btnChooseTeacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="👩 Chọn giáo viên" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>