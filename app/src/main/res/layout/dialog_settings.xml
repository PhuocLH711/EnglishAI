<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#B0BEC5"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ Cài Đặt Hệ Thống"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:id="@+id/itemChangeAvatar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷  Thay đổi ảnh đại diện"
            android:textSize="15sp"
            android:textColor="#37474F"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/itemUpdateInfo"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️  Cập nhật thông tin cá nhân"
            android:textSize="15sp"
            android:textColor="#37474F"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/itemHelp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❓  Hướng dẫn sử dụng &amp; Trợ giúp"
            android:textSize="15sp"
            android:textColor="#37474F"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CFD8DC"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/dialogBtnLogout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_button_quiz"
        android:backgroundTint="#FFEBEE"
        android:text="🚪 Đăng xuất tài khoản"
        android:textColor="#C62828"
        android:textSize="14sp"
        android:textStyle="bold"
        android:elevation="0dp"/>

</LinearLayout>